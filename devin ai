<script>
(function() {
    // Private flag — not accessible from global scope
    let captchaSolved = false;

    // Block form submission if the captcha hasn't been solved yet.
    // Use preventDefault() only (NOT stopImmediatePropagation) so that
    // jQuery Validate's own submit handler still runs and renders the
    // field-level error messages. This way validation errors show up
    // immediately when the user clicks Register, even before the
    // reCAPTCHA has been solved.
    document.getElementById('emailForm').addEventListener('submit', function(e) {
        if (!captchaSolved) {
            e.preventDefault();
            return false;
        }
    });

    // Captcha callback — only way to flip the flag
    function enableSubmitButton() {
        captchaSolved = true;
    }

    // Render reCAPTCHA
    window.onloadCallback = function() {
        grecaptcha.render('recaptcha-widget', {
            'sitekey': '6LchSJMpAAAAAOpvZFRoMM9WEHhMLARnsjNTRFBi',
            //'sitekey' : '6LfxP8UqAAAAAB2D8cItbCOE4Db_KbY7vf2daCSR',//LOCALHOST
            'callback': enableSubmitButton
        });
    };
})();

</script>
<script src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit" async defer></script>
